# =========================
# VSH runtime defaults
# =========================
# mock | gemini | openai
LLM_PROVIDER=gemini

# Gemini
GOOGLE_API_KEY=
# legacy fallback
GEMINI_API_KEY=

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4.1-mini

# Optional local paths (cwd-independent defaults are in config.py)
LOG_PATH=

# API endpoints for Desktop/VSCode
VSH_API_URL=http://127.0.0.1:3000
VITE_VSH_API_URL=http://127.0.0.1:3000
VITE_API_BASE_URL=http://127.0.0.1:3000
VSH_WATCH_ON_SAVE=false

# Electron main process option (desktop-only)
VSH_AUTO_START_API=false
