# VSH environment template

# Optional LLM integration
LLM_PROVIDER=mock
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional L3 / Sonar integration
SONAR_TOKEN=
SONARQUBE_TOKEN=
SONAR_URL=https://sonarcloud.io
SONARQUBE_URL=http://localhost:9000
SONAR_ORG=
SONAR_PROJECT_KEY=vsh-local
SONARQUBE_PROJECT_KEY=vsh_project

# Optional local CLI tooling
SEMGREP_PATH=
SYFT_PATH=

# API defaults
API_HOST=127.0.0.1
API_PORT=3000

# Desktop/API behavior
VSH_AUTO_START_API=true
VSH_USE_DIST=true
