# VSH Configuration Template
# Copy this to .env and update with your actual values

# ============================
# L1: SAST Scanner
# ============================
L1_ENABLED=true

# ============================
# L2: LLM Reasoning
# ============================
L2_ENABLED=true
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# ============================
# L3: Evidence-based Verification
# ============================
L3_ENABLED=true
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=your_sonarqube_token_here
SONARQUBE_PROJECT_KEY=vsh_project

# Docker (for L3 PoC containerization)
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=
DOCKER_PASSWORD=

# SBOM Generation
SBOM_TOOL=cyclonedx
SBOM_FORMAT=json

# ============================
# API Configuration
# ============================
API_HOST=127.0.0.1
API_PORT=3000
API_LOG_LEVEL=INFO

# ============================
# Database
# ============================
DB_PATH=./mock_db
LOG_DB_PATH=./mock_db/log.json

# ============================
# Logging
# ============================
LOG_LEVEL=INFO
LOG_FILE=./logs/vsh.log
